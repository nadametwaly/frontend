# ─── Node / npm artifacts ────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.yarn/
.pnp.*

# ─── Angular build output ────────────────────────────────────────────────────
dist/
.angular/
out-tsc/
tmp/
*.tsbuildinfo

# ─── Test / coverage output ──────────────────────────────────────────────────
coverage/
karma-results/
e2e/.tmp/
.nyc_output/

# ─── IDE / editor noise ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── Git / VCS ───────────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes
.github/
.gitlab-ci.yml

# ─── Docker / compose / CI (never ship into the image) ───────────────────────
Dockerfile
Dockerfile.*
.dockerignore
docker-compose*.yml
.devcontainer/

# ─── Secrets and local config ────────────────────────────────────────────────
.env
.env.*
*.local
src/environments/environment.local.ts

# ─── Logs / runtime junk ─────────────────────────────────────────────────────
*.log
logs/

# ─── Docs / repo metadata not needed at build time ───────────────────────────
README.md
README*.md
CHANGELOG.md
LICENSE
docs/
